---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import PostSortControls from "../../components/PostSortControls.astro";
import { getTagMap, sortPosts } from "../../lib/content";

export async function getStaticPaths() {
  const tagMap = await getTagMap();

  return [...tagMap.entries()].map(([tag, posts]) => ({
    params: { tag },
    props: { tag, posts }
  }));
}

const { tag, posts } = Astro.props;
const sortedPosts = sortPosts(posts);
---

<BaseLayout title={`标签：${tag}`} description={`查看与 ${tag} 相关的所有文章。`}>
  <section class="shell archive-shell">
    <header class="page-heading">
      <p class="eyebrow">Tag</p>
      <h1>{tag}</h1>
      <p>共收录 {posts.length} 篇相关文章。</p>
    </header>

    <div data-post-sort-root>
      <PostSortControls />

      <div class="post-grid js-sortable-post-grid">
        {sortedPosts.map((post) => (
          <div
            class="js-sortable-post"
            data-title={post.data.title}
            data-date-timestamp={post.data.pubDate.getTime()}
          >
            <PostCard post={post} />
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
