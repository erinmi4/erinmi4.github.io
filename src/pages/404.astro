---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not Found" description="The page you requested does not exist or has moved.">
  <section class="shell not-found">
    <p class="eyebrow">404</p>
    <h1>This page is no longer here.</h1>
    <p>
      Some older links from the previous site no longer resolve cleanly. The archive is the best place to restart.
    </p>
    <div class="hero__actions">
      <a class="button button--primary" href="/archives/">Open archive</a>
      <a class="button" href="/">Return home</a>
    </div>
  </section>
</BaseLayout>
