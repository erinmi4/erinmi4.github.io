---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, getAllPosts, getArchiveGroups, getCategoryUrl, getPostUrl } from "../../lib/content";

const groups = await getArchiveGroups();
const posts = await getAllPosts();
---

<BaseLayout title="博客归档" description="按时间浏览博客中的所有文章。">
  <section class="shell archive-shell">
    <header class="page-heading">
      <p class="eyebrow">Archive</p>
      <h1>博客归档</h1>
      <p>按时间线查看所有文章，也可以继续使用按月份整理的归档分组。</p>
    </header>

    <section class="timeline-shell">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Timeline</p>
          <h2>按时间线排序</h2>
        </div>
      </div>

      <div class="timeline-list">
        {posts.map((post) => (
          <article class="timeline-item">
            <div class="timeline-item__date">{formatDate(post.data.pubDate)}</div>
            <div class="timeline-item__dot" aria-hidden="true"></div>
            <div class="timeline-item__content">
              <a class="timeline-item__category" href={getCategoryUrl(post.data.category)}>
                {post.data.category}
              </a>
              <h3>
                <a href={getPostUrl(post)}>{post.data.title}</a>
              </h3>
              <p>{post.data.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <div class="archive-groups">
      {
        groups.map((group) => (
          <section class="archive-group">
            <div class="archive-group__title">
              <h2>
                {group.year} 年 {group.month} 月
              </h2>
              <span>{group.entries.length} 篇</span>
            </div>

            <div class="archive-group__list">
              {group.entries.map((post) => (
                <article class="archive-item">
                  <div>
                    <p>{formatDate(post.data.pubDate)}</p>
                    <h3>
                      <a href={getPostUrl(post)}>{post.data.title}</a>
                    </h3>
                  </div>
                  <a href={getCategoryUrl(post.data.category)}>{post.data.category}</a>
                </article>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </section>
</BaseLayout>
