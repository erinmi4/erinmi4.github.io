{
  "name": "erinmi4.github.io",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Modern Astro-powered personal blog for erinmi4.",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node ./scripts/validate-content.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check && tsc --noEmit",
    "new:post": "node ./scripts/new-post.mjs",
    "publish": "powershell -ExecutionPolicy Bypass -File .\\scripts\\publish.ps1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/rss": "^4.0.0",
    "@astrojs/sitemap": "^3.0.0",
    "@types/node": "^24.0.0",
    "astro": "^5.0.0",
    "katex": "^0.16.45",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "typescript": "^5.0.0"
  }
}
