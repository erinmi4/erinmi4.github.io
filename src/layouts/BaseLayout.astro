---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { siteConfig } from "../lib/site";
import "katex/dist/katex.min.css";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  pageClass?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  image = "/social-card.svg",
  pageClass = ""
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, siteConfig.siteUrl).toString();
const pageTitle = title === siteConfig.title ? title : `${title} | ${siteConfig.title}`;
const socialImage = new URL(image, siteConfig.siteUrl).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={siteConfig.title} href="/rss.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:site_name" content={siteConfig.title} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="theme-color" content="#08111f" />
  </head>

  <body class={pageClass}>
    <div class="site-backdrop" aria-hidden="true"></div>
    <div class="page-aura" aria-hidden="true">
      <span class="page-aura__beam page-aura__beam--one"></span>
      <span class="page-aura__beam page-aura__beam--two"></span>
      <span class="page-aura__halo page-aura__halo--one"></span>
      <span class="page-aura__halo page-aura__halo--two"></span>
      <span class="page-aura__grid"></span>
    </div>
    <div class="pointer-effects" aria-hidden="true">
    </div>
    <div class="page-shell">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
    <script is:inline>
      (() => {
        const media = window.matchMedia("(hover: hover) and (pointer: fine)");
        if (!media.matches) return;

        const body = document.body;
        const layer = document.querySelector(".pointer-effects");

        if (!(layer instanceof HTMLElement)) {
          return;
        }

        body.classList.add("has-custom-pointer");

        const spawnBurst = (x, y) => {
          const burst = document.createElement("span");
          burst.className = "pointer-burst";
          burst.style.left = `${x}px`;
          burst.style.top = `${y}px`;

          for (let index = 0; index < 7; index += 1) {
            const particle = document.createElement("span");
            particle.className = "pointer-burst__particle";
            particle.style.setProperty("--angle", `${index * 51}deg`);
            burst.appendChild(particle);
          }

          layer.appendChild(burst);
          window.setTimeout(() => burst.remove(), 620);
        };

        document.addEventListener("mousedown", (event) => {
          spawnBurst(event.clientX, event.clientY);
        });
      })();
    </script>
  </body>
</html>
