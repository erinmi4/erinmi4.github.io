---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../lib/projects";
---

<BaseLayout title="Projects" description="Selected projects across embedded systems, blogging infrastructure, and study workflows.">
  <section class="shell archive-shell">
    <header class="page-heading">
      <p class="eyebrow">Projects</p>
      <h1>Selected projects</h1>
      <p>Work with real implementation detail, not placeholder polish.</p>
    </header>

    <div class="project-grid">
      {
        projects.map((project) => (
          <article class="project-card">
            <div class="project-card__top">
              <div>
                <p class="project-card__status">{project.status}</p>
                <h2>{project.title}</h2>
              </div>
              <span class="project-card__period">{project.period}</span>
            </div>

            <p class="project-card__summary">{project.summary}</p>

            <dl class="project-card__meta">
              <div>
                <dt>Role</dt>
                <dd>{project.role}</dd>
              </div>
              <div>
                <dt>Stack</dt>
                <dd>{project.technologies.join(" / ")}</dd>
              </div>
            </dl>

            <ul class="project-card__highlights">
              {project.highlights.map((highlight) => <li>{highlight}</li>)}
            </ul>

            <div class="project-card__actions">
              {project.relatedPost && <a class="button button--secondary" href={project.relatedPost}>Related post</a>}
              {project.repository && (
                <a class="button button--secondary" href={project.repository} rel="noreferrer" target="_blank">
                  Repository
                </a>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
