---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../lib/projects";
---

<BaseLayout title="项目" description="围绕嵌入式、博客重建与学习系统的项目整理。">
  <section class="shell archive-shell">
    <header class="page-heading">
      <p class="eyebrow">Projects</p>
      <h1>项目整理</h1>
      <p>这里收录当前已经有真实内容支撑、并且我愿意持续整理的项目。</p>
    </header>

    <div class="project-grid">
      {
        projects.map((project) => (
          <article class="project-card">
            <div class="project-card__top">
              <div>
                <p class="project-card__status">{project.status}</p>
                <h2>{project.title}</h2>
              </div>
              <span class="project-card__period">{project.period}</span>
            </div>

            <p class="project-card__summary">{project.summary}</p>

            <dl class="project-card__meta">
              <div>
                <dt>角色</dt>
                <dd>{project.role}</dd>
              </div>
              <div>
                <dt>技术栈</dt>
                <dd>{project.technologies.join(" / ")}</dd>
              </div>
            </dl>

            <ul class="project-card__highlights">
              {project.highlights.map((highlight) => <li>{highlight}</li>)}
            </ul>

            <div class="project-card__actions">
              {project.relatedPost && <a class="button" href={project.relatedPost}>相关博客</a>}
              {project.repository && (
                <a class="button button--secondary" href={project.repository} rel="noreferrer" target="_blank">
                  查看仓库
                </a>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
