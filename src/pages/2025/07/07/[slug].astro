---
import RedirectLayout from "../../../../layouts/RedirectLayout.astro";

export function getStaticPaths() {
  return [
    {
      params: { slug: "hello-world" },
      props: {
        to: "/posts/hello-world/",
        title: "旧链接跳转"
      }
    }
  ];
}

const { to, title } = Astro.props;
---

<RedirectLayout to={to} title={title} />
