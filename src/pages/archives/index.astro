---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatDate,
  getArchiveGroups,
  getCategoryUrl,
  getDateAnchorId,
  getPostUrl,
  getTimelineGroups
} from "../../lib/content";

const groups = await getArchiveGroups();
const timelineGroups = await getTimelineGroups();
---

<BaseLayout title="Archive" description="Browse every post by date.">
  <section class="shell archive-shell">
    <header class="page-heading">
      <p class="eyebrow">Archive</p>
      <h1>Archive</h1>
      <p>Browse the full body of writing by timeline or by month.</p>
    </header>

    <section class="timeline-shell">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Timeline</p>
          <h2>Timeline view</h2>
        </div>
      </div>

      <div class="timeline-list">
        {timelineGroups.map((group) => (
          <article class="timeline-item">
            <div class="timeline-item__date">{formatDate(group.date)}</div>
            <a
              class="timeline-item__dot-link"
              href={`#${getDateAnchorId(group.key)}`}
              aria-label={`Jump to the archive section for ${formatDate(group.date)}`}
            >
              <span class="timeline-item__dot" aria-hidden="true"></span>
            </a>
            <div class="timeline-item__content">
              <div class="timeline-item__header">
                <h3>
                  {group.entries.length > 1
                    ? `${group.entries[0].data.title} and ${group.entries.length - 1} more`
                    : group.entries[0].data.title}
                </h3>
                <span class="timeline-item__count">{group.entries.length} article{group.entries.length > 1 ? "s" : ""}</span>
              </div>

              <div class="timeline-item__posts">
                {group.entries.map((post) => (
                  <article class="timeline-entry">
                    <a class="timeline-item__category" href={getCategoryUrl(post.data.category)}>
                      {post.data.category}
                    </a>
                    <h4>
                      <a href={getPostUrl(post)}>{post.data.title}</a>
                    </h4>
                    <p>{post.data.description}</p>
                  </article>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <div class="archive-groups">
      {
        groups.map((group) => (
          <section class="archive-group">
            <div class="archive-group__title">
              <h2>{group.year} / {group.month}</h2>
              <span>{group.entries.length} article{group.entries.length > 1 ? "s" : ""}</span>
            </div>

            {group.dayGroups.map((dayGroup) => (
              <section class="archive-day" id={getDateAnchorId(dayGroup.key)}>
                <div class="archive-day__header">
                  <h3>{formatDate(dayGroup.date)}</h3>
                  <span>{dayGroup.entries.length} article{dayGroup.entries.length > 1 ? "s" : ""}</span>
                </div>

                <div class="archive-group__list">
                  {dayGroup.entries.map((post) => (
                    <article class="archive-item">
                      <div>
                        <p>{formatDate(post.data.pubDate)}</p>
                        <h4>
                          <a href={getPostUrl(post)}>{post.data.title}</a>
                        </h4>
                      </div>
                      <a href={getCategoryUrl(post.data.category)}>{post.data.category}</a>
                    </article>
                  ))}
                </div>
              </section>
            ))}
          </section>
        ))
      }
    </div>
  </section>
</BaseLayout>
