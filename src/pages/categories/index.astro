---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCategoryMap } from "../../lib/content";

const categoryMap = await getCategoryMap();
const categories = [...categoryMap.entries()];
---

<BaseLayout title="Categories" description="Browse the archive by category.">
  <section class="shell archive-shell">
    <header class="page-heading">
      <p class="eyebrow">Categories</p>
      <h1>Categories</h1>
      <p>Use category pages to move through the archive by content lane.</p>
    </header>

    <div class="taxonomy-grid">
      {categories.map(([category, posts]) => (
        <a class="taxonomy-card" href={`/categories/${encodeURIComponent(category)}/`}>
          <h2>{category}</h2>
          <p>{posts.length} article{posts.length > 1 ? "s" : ""}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
