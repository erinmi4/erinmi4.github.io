---
import type { BlogEntry } from "../lib/content";
import BaseLayout from "./BaseLayout.astro";
import CodeCopyControls from "../components/CodeCopyControls.astro";
import TagList from "../components/TagList.astro";
import TableOfContents from "../components/TableOfContents.astro";
import { formatDate, getCategoryUrl, getPostUrl } from "../lib/content";

interface HeadingItem {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  post: BlogEntry;
  previousPost?: BlogEntry;
  nextPost?: BlogEntry;
  readingMinutes: number;
  headings: HeadingItem[];
}

const { post, previousPost, nextPost, readingMinutes, headings } = Astro.props;
---

<BaseLayout title={post.data.title} description={post.data.description} pageClass="page-post">
  <article class="shell post-shell">
    <header class:list={["post-hero", { "has-hero-image": Boolean(post.data.heroImage) }]}>
      {
        post.data.heroImage && (
          <img
            class="post-hero__image"
            src={post.data.heroImage}
            alt={post.data.title}
            loading="lazy"
          />
        )
      }

      <div class="post-hero__content">
        <p class="eyebrow">Article</p>
        <h1>{post.data.title}</h1>
        <p class="post-hero__description">{post.data.description}</p>

        <div class="post-hero__meta">
          <span>{formatDate(post.data.pubDate)}</span>
          <a href={getCategoryUrl(post.data.category)}>{post.data.category}</a>
          <span>{readingMinutes} min read</span>
        </div>

        <TagList tags={post.data.tags} />
      </div>
    </header>

    <div class="post-shell__body">
      <aside class="post-shell__aside">
        <section class="post-info-card">
          <p class="post-info-card__eyebrow">Reading notes</p>
          <dl class="post-info-card__list">
            <div>
              <dt>Published</dt>
              <dd>{formatDate(post.data.pubDate)}</dd>
            </div>
            <div>
              <dt>Category</dt>
              <dd>{post.data.category}</dd>
            </div>
            <div>
              <dt>Reading time</dt>
              <dd>{readingMinutes} minutes</dd>
            </div>
          </dl>
        </section>

        <TableOfContents headings={headings} />
      </aside>

      <div class="prose-card post-prose">
        <slot />
      </div>
    </div>

    <nav class="post-nav" aria-label="Article navigation">
      <div>
        {
          previousPost && (
            <>
              <span>Previous</span>
              <a href={getPostUrl(previousPost)}>{previousPost.data.title}</a>
            </>
          )
        }
      </div>

      <div>
        {
          nextPost && (
            <>
              <span>Next</span>
              <a href={getPostUrl(nextPost)}>{nextPost.data.title}</a>
            </>
          )
        }
      </div>
    </nav>
  </article>
  <CodeCopyControls />
</BaseLayout>
