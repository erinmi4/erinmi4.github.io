---
import { render } from "astro:content";
import MarkdownPageLayout from "../layouts/MarkdownPageLayout.astro";
import { getPageBySlug } from "../lib/content";
import { siteConfig } from "../lib/site";

const page = await getPageBySlug("about");

if (!page) {
  throw new Error("Missing about page content.");
}

const { Content } = await render(page);
---

<MarkdownPageLayout title="About" description="A profile note on the person, projects, and study systems behind this site.">
  <section class="profile-card">
    <div class="profile-card__content">
      <p class="profile-card__eyebrow">Profile</p>
      <h2>{siteConfig.author} / {siteConfig.handle}</h2>
      <p>{siteConfig.bio}</p>
      <div class="profile-card__quick-links">
        <a class="button button--primary" href={siteConfig.social.github} rel="noreferrer" target="_blank">
          View GitHub
        </a>
        <a class="button" href={`mailto:${siteConfig.email}`}>
          Contact
        </a>
      </div>
    </div>

    <div class="profile-card__visual">
      <img
        class="profile-card__portrait"
        src={siteConfig.profileImage.src}
        alt={siteConfig.profileImage.alt}
        loading="lazy"
      />
      <p class="media-credit">
        <a href={siteConfig.profileImage.creditHref} rel="noreferrer" target="_blank">
          {siteConfig.profileImage.creditText}
        </a>
      </p>
      <dl class="profile-card__meta">
        <div>
          <dt>Base</dt>
          <dd>{siteConfig.location}</dd>
        </div>
        <div>
          <dt>GitHub</dt>
          <dd>
            <a href={siteConfig.social.github} rel="noreferrer" target="_blank">
              {siteConfig.handle}
            </a>
          </dd>
        </div>
        <div>
          <dt>Email</dt>
          <dd>
            <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
          </dd>
        </div>
      </dl>
    </div>
  </section>

  <Content />
</MarkdownPageLayout>
