---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import PostSortControls from "../../components/PostSortControls.astro";
import { getCategoryMap, sortPosts } from "../../lib/content";

export async function getStaticPaths() {
  const categoryMap = await getCategoryMap();

  return [...categoryMap.entries()].map(([category, posts]) => ({
    params: { category },
    props: { category, posts }
  }));
}

const { category, posts } = Astro.props;
const sortedPosts = sortPosts(posts);
---

<BaseLayout
  title={`Category: ${category}`}
  description={`Browse every post filed under ${category}.`}
>
  <section class="shell archive-shell">
    <header class="page-heading">
      <p class="eyebrow">Category</p>
      <h1>{category}</h1>
      <p>{posts.length} article{posts.length > 1 ? "s" : ""} in this lane.</p>
    </header>

    <div data-post-sort-root>
      <PostSortControls />

      <div class="post-grid js-sortable-post-grid">
        {sortedPosts.map((post) => (
          <div
            class="js-sortable-post"
            data-title={post.data.title}
            data-date-timestamp={post.data.pubDate.getTime()}
          >
            <PostCard post={post} />
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
