---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Search" description="Search across posts and standalone pages.">
  <section class="shell archive-shell">
    <header class="page-heading">
      <p class="eyebrow">Search</p>
      <h1>Search the archive</h1>
      <p>Search across titles, summaries, body text, tags, and categories.</p>
    </header>

    <section class="search-shell">
      <label class="search-shell__label" for="site-search">
        Search query
      </label>
      <input
        class="search-shell__input"
        id="site-search"
        type="search"
        placeholder="Try 修考, ESP32, probability, or 博客重建"
      />
      <p class="search-shell__hint">Results update as you type.</p>
      <div class="search-results" id="search-results">
        <p class="search-results__empty">Start with a keyword and the matching notes will appear here.</p>
      </div>
    </section>
  </section>

  <script is:inline>
    const input = document.querySelector("#site-search");
    const container = document.querySelector("#search-results");

    const renderEmpty = (message) => {
      if (!container) return;
      container.innerHTML = `<p class="search-results__empty">${message}</p>`;
    };

    const highlight = (text, keyword) => {
      if (!keyword) return text;
      const escaped = keyword.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
      return text.replace(new RegExp(escaped, "gi"), (match) => `<mark>${match}</mark>`);
    };

    fetch("/search-index.json")
      .then((response) => response.json())
      .then((records) => {
        if (!input || !container) return;

        input.addEventListener("input", () => {
          const keyword = input.value.trim().toLowerCase();

          if (!keyword) {
            renderEmpty("Start with a keyword and the matching notes will appear here.");
            return;
          }

          const matches = records
            .map((record) => {
              const haystack = [
                record.title,
                record.description,
                record.body,
                record.category,
                ...(record.tags || [])
              ]
                .join(" ")
                .toLowerCase();

              return { ...record, score: haystack.includes(keyword) ? haystack.indexOf(keyword) : -1 };
            })
            .filter((record) => record.score >= 0)
            .sort((left, right) => left.score - right.score)
            .slice(0, 20);

          if (matches.length === 0) {
            renderEmpty("No matching results yet. Try a broader or different keyword.");
            return;
          }

          container.innerHTML = matches
            .map((record) => {
              const snippetSource = `${record.description} ${record.body || ""}`.replace(/\s+/g, " ").trim();
              const snippet = snippetSource.slice(0, 140);

              return `
                <article class="search-result-card">
                  <div class="search-result-card__meta">
                    <span>${record.type === "post" ? "Article" : "Page"}</span>
                    <span>${record.category}</span>
                  </div>
                  <h2><a href="${record.url}">${highlight(record.title, keyword)}</a></h2>
                  <p>${highlight(snippet, keyword)}...</p>
                  <div class="search-result-card__tags">
                    ${(record.tags || []).map((tag) => `<span>${tag}</span>`).join("")}
                  </div>
                </article>
              `;
            })
            .join("");
        });
      })
      .catch(() => {
        renderEmpty("Search index failed to load. Please try again later.");
      });
  </script>
</BaseLayout>
