---
import { navItems, siteConfig } from "../lib/site";

const pathname = Astro.url.pathname;
---

<header class="site-header">
  <div class="shell site-header__inner">
    <a class="brand" href="/">
      <span class="brand__mark">
        <img src="/images/portraits/mika-avatar.svg" alt="" />
      </span>
      <span class="brand__stack">
        <span class="brand__text">{siteConfig.author}</span>
        <span class="brand__subtext">Tokyo Signal</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      {
        navItems.map((item) => {
          const active =
            item.href === "/"
              ? pathname === item.href
              : pathname === item.href || pathname.startsWith(item.href);

          return (
            <a class:list={["site-nav__link", { "is-active": active }]} href={item.href}>
              {item.label}
            </a>
          );
        })
      }

      <button class="theme-toggle" type="button" data-theme-toggle aria-label="切换主题">
        <span class="theme-toggle__icon" aria-hidden="true">◐</span>
        <span class="theme-toggle__label" data-theme-toggle-label>浅色模式</span>
      </button>
    </nav>
  </div>
</header>
