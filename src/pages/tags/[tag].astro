---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import PostSortControls from "../../components/PostSortControls.astro";
import { getTagMap, sortPosts } from "../../lib/content";

export async function getStaticPaths() {
  const tagMap = await getTagMap();

  return [...tagMap.entries()].map(([tag, posts]) => ({
    params: { tag },
    props: { tag, posts }
  }));
}

const { tag, posts } = Astro.props;
const sortedPosts = sortPosts(posts);
---

<BaseLayout title={`Topic: ${tag}`} description={`Browse every post tagged with ${tag}.`}>
  <section class="shell archive-shell">
    <header class="page-heading">
      <p class="eyebrow">Topic</p>
      <h1>{tag}</h1>
      <p>{posts.length} related article{posts.length > 1 ? "s" : ""}.</p>
    </header>

    <div data-post-sort-root>
      <PostSortControls />

      <div class="post-grid js-sortable-post-grid">
        {sortedPosts.map((post) => (
          <div
            class="js-sortable-post"
            data-title={post.data.title}
            data-date-timestamp={post.data.pubDate.getTime()}
          >
            <PostCard post={post} />
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
